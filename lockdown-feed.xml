---
layout: null
permalink: /lockdown-feed.xml
---
<?xml version="1.0" encoding="utf-8"?>
<feed xmlns="http://www.w3.org/2005/Atom" xmlns:media="http://search.yahoo.com/mrss/">
  <generator uri="https://shimiscyberworld.com/" version="1.0">SCW Lockdown Lab</generator>
  <link href="{{ '/lockdown-feed.xml' | absolute_url }}" rel="self" type="application/atom+xml" />
  <link href="{{ '/lockdown-lab/' | absolute_url }}" rel="alternate" type="text/html" />
  <updated>{{ site.time | date_to_xmlschema }}</updated>
  <id>{{ '/lockdown-feed.xml' | absolute_url }}</id>
  <title type="html">SCW Lockdown Lab — Daily Hardening Tips</title>
  <subtitle>One practical hardening tip per day — Shimi Cohen, Shimi's Cyber World.</subtitle>
  {% assign lockdowns = site.posts | where: "section", "lockdown" %}
  {% for post in lockdowns limit:200 %}
  <entry>
    <title type="html">{{ post.title | xml_escape }}</title>
    <link href="{{ post.url | absolute_url }}" rel="alternate" type="text/html" title="{{ post.title | xml_escape }}" />
    <published>{{ post.date | date_to_xmlschema }}</published>
    <updated>{{ post.date | date_to_xmlschema }}</updated>
    <id>{{ post.url | absolute_url }}</id>
    <content type="html" xml:base="{{ post.url | absolute_url }}"><![CDATA[{{ post.content }}]]></content>
    <author><name>Shimi Cohen</name></author>
    {% for tag in post.tags %}<category term="{{ tag }}" />
    {% endfor %}
    <summary type="html"><![CDATA[{{ post.summary | default: post.excerpt | strip_html | truncate: 240 }}]]></summary>
    {% if post.image %}<media:thumbnail url="{{ post.image | xml_escape }}" />
    <media:content medium="image" url="{{ post.image | xml_escape }}" />{% endif %}
  </entry>
  {% endfor %}
</feed>
