---
layout: null
---
<?xml version="1.0" encoding="utf-8"?>
<feed xmlns="http://www.w3.org/2005/Atom" xmlns:scw="https://shimiscyberworld.com/ns/1.0" xmlns:media="http://search.yahoo.com/mrss/">
  <generator uri="https://shimiscyberworld.com/" version="3.0">SCW Feed Engine</generator>
  <link href="{{ '/feed.xml' | absolute_url }}" rel="self" type="application/atom+xml" />
  <link href="{{ site.url }}" rel="alternate" type="text/html" />
  <updated>{{ site.time | date_to_xmlschema }}</updated>
  <id>{{ '/feed.xml' | absolute_url }}</id>
  <title type="html">{{ site.title | xml_escape }}</title>
  <subtitle>{{ site.description | xml_escape }}</subtitle>
  <link href="https://t.me/Shimiscyberworldbot" rel="related" type="text/html" title="SCW Intel Bot — Real threat intelligence inside Telegram. Search, monitor, and generate analyst-ready outputs." />
  {% assign posts = site.posts | where_exp: "post", "post.hidden != true" %}
  {% for post in posts limit:200 %}
  <entry>
    <title type="html">{{ post.title | xml_escape }}</title>
    <link href="{{ post.url | absolute_url }}" rel="alternate" type="text/html" title="{{ post.title | xml_escape }}" />
    <published>{{ post.date | date_to_xmlschema }}</published>
    <updated>{{ post.date | date_to_xmlschema }}</updated>
    <id>{{ post.url | absolute_url }}</id>
    <content type="html" xml:base="{{ post.url | absolute_url }}"><![CDATA[{{ post.content }}]]></content>
    <author><name>{{ site.title | xml_escape }}</name></author>
    {% for tag in post.tags %}<category term="{{ tag }}" />
    {% endfor %}
    <summary type="html"><![CDATA[{{ post.summary | default: post.excerpt | strip_html | truncate: 180 }}]]></summary>
    {% if post.image %}<media:thumbnail url="{{ post.image | xml_escape }}" />
    <media:content medium="image" url="{{ post.image | xml_escape }}" />{% endif %}
    {% comment %}── SCW Structured Threat Intelligence ──{% endcomment %}
    {% comment %}── Classification ──{% endcomment %}
    {% if post.score %}<scw:severity>{{ post.score }}</scw:severity>{% endif %}
    {% if post.cvss_score %}<scw:cvss score="{{ post.cvss_score }}" severity="{{ post.cvss_severity }}"{% if post.cvss_vector %} vector="{{ post.cvss_vector }}"{% endif %} />{% endif %}
    {% if post.event_type %}<scw:event_type>{{ post.event_type }}</scw:event_type>{% elsif post.section == "vulnerabilities" or post.channel == "NVD" %}<scw:event_type>vulnerability</scw:event_type>{% endif %}
    {% if post.section %}<scw:section>{{ post.section }}</scw:section>{% endif %}
    {% if post.tlp %}<scw:tlp>{{ post.tlp }}</scw:tlp>{% else %}<scw:tlp>TLP:CLEAR</scw:tlp>{% endif %}
    {% comment %}── Source Attribution (no direct URLs — Option C) ──{% endcomment %}
    {% if post.channel == "NVD" %}<scw:source name="National Vulnerability Database" channel="NVD" />
    {% elsif post.channel == "Daily Digest" %}<scw:source name="SCW Daily Digest" channel="Digest" />
    {% elsif post.source_name %}<scw:source name="SCW Curated Intelligence" channel="OSINT" />
    {% endif %}
    {% comment %}── Vulnerability Data (NVD) ──{% endcomment %}
    {% if post.cwe %}{% for c in post.cwe %}
    <scw:cwe>{{ c }}</scw:cwe>{% endfor %}{% endif %}
    {% comment %}── Entities ──{% endcomment %}
    {% if post.organizations %}{% for org in post.organizations %}
    <scw:organization name="{{ org.name | xml_escape }}"{% if org.domain %} domain="{{ org.domain | xml_escape }}"{% endif %}{% if org.role %} role="{{ org.role }}"{% endif %} />{% endfor %}{% endif %}
    {% if post.threat_actors %}{% for actor in post.threat_actors %}
    <scw:threat_actor>{{ actor | xml_escape }}</scw:threat_actor>{% endfor %}{% endif %}
    {% if post.malware_families %}{% for mw in post.malware_families %}
    <scw:malware>{{ mw | xml_escape }}</scw:malware>{% endfor %}{% endif %}
    {% if post.countries %}{% for country in post.countries %}
    <scw:country>{{ country }}</scw:country>{% endfor %}{% endif %}
    {% comment %}── IOCs ──{% endcomment %}
    {% if post.iocs %}{% for ioc in post.iocs %}{% unless ioc.type == "cve" or ioc.type == "weakness" %}
    <scw:ioc type="{{ ioc.type | xml_escape }}" indicator="{{ ioc.indicator | xml_escape }}" />{% endunless %}{% endfor %}{% endif %}
    {% comment %}── MITRE ATT&CK ──{% endcomment %}
    {% if post.mitre_attack %}{% for m in post.mitre_attack %}
    <scw:mitre id="{{ m.id }}" name="{{ m.name | xml_escape }}" tactic="{{ m.tactic | xml_escape }}" />{% endfor %}{% endif %}
    {% comment %}── Detection ──{% endcomment %}
    {% if post.sigma_rules %}<scw:detection rules="{{ post.sigma_rules.count | default: 0 }}" free="{{ post.sigma_rules.free | default: 0 }}" />{% endif %}
  </entry>
  {% endfor %}
</feed>
